NIMBLE_API_KEY=

# Optional AI response layer. When configured, Gemini explains the structured
# CPT, benchmark, CMS, MRF, and care-option facts in the user-facing answer.
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash



# Optional: comma-separated local paths or direct URLs to CMS-template hospital MRFs.
# Use Nimble/HospitalPricingFiles to discover URLs, then let the app parse them locally.
HOSPITAL_MRF_SOURCES=
HOSPITAL_MRF_MAX_BYTES=52428800

# Optional ClickHouse warehouse for normalized MRF rows.
# CLICKHOUSE_URL is the database HTTP endpoint, typically https://HOST:8443.
CLICKHOUSE_URL=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=healthcare
CLICKHOUSE_MRF_TABLE=mrf_charges

# Optional ClickHouse Cloud management API credentials. These are not enough
# by themselves for SQL queries; the app also needs the database endpoint above.
CLICKHOUSE_CLOUD_API_KEY_ID=
CLICKHOUSE_CLOUD_API_KEY_SECRET=
